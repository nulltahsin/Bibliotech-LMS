<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #F8F9FA;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.PendingRequestssController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <!-- Branding Header -->
        <VBox spacing="10.0" style="-fx-border-color: #E0E0E0; -fx-border-width: 0 0 1 0;">
            <children>
                <Label text="BiblioTech" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <!-- Navigation Row -->
                <HBox alignment="CENTER_LEFT">
                    <children>
                        <!-- Back Button -->
                        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="← Back">
                            <padding>
                                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                            </padding>
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Button>

                        <!-- This Pane pushes the next button to the far right -->
                        <Pane HBox.hgrow="ALWAYS" />

                        <!-- New Lend Button -->
                        <Button mnemonicParsing="false" onAction="#handleReturnBook" style="-fx-background-color: #ed6637; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="Lend Book">
                            <padding>
                                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                            </padding>
                            <font>
                                <Font name="System Bold" size="14.0" />
                            </font>
                        </Button>
                    </children>
                    <VBox.margin>
                        <Insets bottom="15.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>

        <!-- Page Title -->
        <Label text="Pending Requests" textFill="#343a40">
            <font>
                <Font name="System Bold" size="26.0" />
            </font>
        </Label>

        <!-- Table Container Card -->
        <VBox style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <TableView fx:id="PendingRequestsTable" style="-fx-background-radius: 5; -fx-border-color: #dee2e6; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <!-- Member Name Column (Large) -->
                        <TableColumn fx:id="colMemberName" prefWidth="250.0" text="Member Name" />

                        <!-- Member ID Column (Small) -->
                        <TableColumn fx:id="colMemberId" maxWidth="150.0" minWidth="100.0" prefWidth="120.0" text="Member ID" />

                        <!-- Book Name Column (Large) -->
                        <TableColumn fx:id="colBookName" prefWidth="250.0" text="Book Name" />

                        <!-- Book ID Column (Small) -->
                        <TableColumn fx:id="colBookId" maxWidth="150.0" minWidth="100.0" prefWidth="120.0" text="Book ID" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
