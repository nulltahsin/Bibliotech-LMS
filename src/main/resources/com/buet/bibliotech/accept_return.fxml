<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="15.0" style="-fx-padding: 0; -fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.AcceptReturnController">

    <children>
        <!-- UPPER HEADER (Synced with Dashboard) -->
        <VBox spacing="0.0" prefWidth="1000.0" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-width: 0 0 1 0; -fx-padding: 20 20 10 20;">
            <children>
                <Text fill="#f2f5f9" strokeType="OUTSIDE" strokeWidth="0.0" text="BiblioTech">
                    <font>
                        <Font name="Impact" size="28.0"/>
                    </font>
                </Text>
            </children>
        </VBox>

        <!-- CONTENT AREA (Internal Padding) -->
        <VBox spacing="15.0" VBox.vgrow="ALWAYS" style="-fx-padding: 0 25 25 25;">
            <children>
                <!-- BACK BUTTON -->
                <Button onAction="#handleBack" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="← Back" />

                <!-- PAGE TITLE -->
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold;" text="Return Requests Queue" textFill="#f2f5f9" />

                <!-- TABLEVIEW (Integrated Friend's Height and Your IDs) -->
                <TableView fx:id="returnTable" fixedCellSize="64.0" style="-fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colBookId" prefWidth="150" text="Book ID" />
                        <TableColumn fx:id="colBookName" prefWidth="300" text="Book Name" />
                        <TableColumn fx:id="colMemberId" prefWidth="150" text="Member ID" />
                        <TableColumn fx:id="colAction" prefWidth="150" text="Action" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>