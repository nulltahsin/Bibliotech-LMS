<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #0b1324;" stylesheets="@memberdashboard.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.MemberMessagesController">
    <children>
        <VBox spacing="15.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="20.0">
                    <children>
                        <Button onAction="#handleBack" styleClass="sidebar-button" text="← Back to Dashboard" />
                        <Label text="Inbox" textFill="#f2f5f9">
                            <font><Font name="System Bold" size="24.0" /></font>
                        </Label>
                    </children>
                </HBox>

                <VBox spacing="10.0" style="-fx-background-color: #111c30; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                    <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                    <children>
                        <ScrollPane fitToWidth="true" style="-fx-background: #0f1a2e; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                            <content>
                                <VBox fx:id="chatDisplayBox" spacing="10.0" style="-fx-background-color: #0f1a2e; -fx-padding: 10;" />
                            </content>
                        </ScrollPane>
                        <HBox spacing="10.0">
                            <children>
                                <TextField fx:id="messageInputField" promptText="Type your reply here..." style="-fx-background-color: #0f1a2e; -fx-text-fill: white; -fx-border-color: #223149;" HBox.hgrow="ALWAYS" />
                                <Button onAction="#handleSendMessage" prefWidth="80.0" style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-weight: bold;" text="SEND" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
