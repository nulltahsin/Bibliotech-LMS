<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.ProfileController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <!-- Top Branding -->
        <Label text="BiblioTech" textFill="#f2f5f9">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>

        <!-- Back Button -->
        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-text-fill: white;" text="← Back">
            <padding>
                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
            </padding>
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <!-- Centered Profile Card -->
        <StackPane VBox.vgrow="ALWAYS">
            <children>
                <VBox alignment="TOP_CENTER" maxWidth="700.0" spacing="10.0" style="-fx-background-color: #111c30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 20, 0, 0, 10);">
                    <padding>
                        <Insets bottom="50.0" left="60.0" right="60.0" top="40.0" />
                    </padding>
                    <children>
                        <!-- Title -->
                        <Label text="My Profile" textFill="#f2f5f9">
                            <font>
                                <Font name="System Bold" size="28.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="30.0" />
                            </VBox.margin>
                        </Label>

                        <!-- Data Grid -->
                        <GridPane vgap="15.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="150.0" prefWidth="200.0" />
                                <ColumnConstraints hgrow="ALWAYS" minWidth="300.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints minHeight="40.0" valignment="CENTER" />
                                <RowConstraints minHeight="40.0" valignment="CENTER" />
                                <RowConstraints minHeight="40.0" valignment="CENTER" />
                                <RowConstraints minHeight="40.0" valignment="CENTER" />
                                <RowConstraints minHeight="40.0" valignment="CENTER" />
                            </rowConstraints>
                            <children>
                                <!-- Name Row -->
                                <Label text="Name" textFill="#c7d1e0" GridPane.rowIndex="0">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                    <TextField fx:id="profileName" editable="false"
                                               style="-fx-background-color: #0b1324; -fx-control-inner-background: #0b1324; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 5;"
                                               text="Loading..." />
                                    <Separator style="-fx-opacity: 0.1;" />
                                </VBox>

                                <!-- Member ID Row -->
                                <Label text="Member ID" textFill="#c7d1e0" GridPane.rowIndex="1">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                    <TextField fx:id="profileID" editable="false"
                                               style="-fx-background-color: #1a263e; -fx-control-inner-background: #1a263e; -fx-text-fill: #8b9bb4; -fx-font-size: 16px; -fx-background-radius: 5;"
                                               text="Loading..." />
                                    <Separator style="-fx-opacity: 0.1;" />
                                </VBox>

                                <!-- Email Row -->
                                <Label text="Email" textFill="#c7d1e0" GridPane.rowIndex="2">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                    <TextField fx:id="profileEmail" editable="false"
                                               style="-fx-background-color: #0b1324; -fx-control-inner-background: #0b1324; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 5;"
                                               text="Loading..." />
                                    <Separator style="-fx-opacity: 0.1;" />
                                </VBox>

                                <!-- Department Row -->
                                <Label text="Department" textFill="#c7d1e0" GridPane.rowIndex="3">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                    <TextField fx:id="profileDept" editable="false"
                                               style="-fx-background-color: #0b1324; -fx-control-inner-background: #0b1324; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 5;"
                                               text="Loading..." />
                                    <Separator style="-fx-opacity: 0.1;" />
                                </VBox>

                                <!-- Batch Row -->
                                <Label text="Batch" textFill="#c7d1e0" GridPane.rowIndex="4">
                                    <font><Font name="System Bold" size="16.0" /></font>
                                </Label>
                                <VBox spacing="5.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                    <TextField fx:id="profileBatch" editable="false"
                                               style="-fx-background-color: #0b1324; -fx-control-inner-background: #0b1324; -fx-text-fill: white; -fx-font-size: 16px; -fx-background-radius: 5;"
                                               text="Loading..." />
                                    <Separator style="-fx-opacity: 0.1;" />
                                </VBox>
                            </children>
                        </GridPane>

                        <!-- Action Buttons -->
                        <HBox alignment="CENTER_RIGHT" spacing="15.0">
                            <VBox.margin><Insets top="30.0" /></VBox.margin>
                            <children>
                                <Button mnemonicParsing="false" onAction="#enableEditing"
                                        style="-fx-background-color: #1f3b6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Edit Profile">
                                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                                </Button>
                                <Button fx:id="saveButton" mnemonicParsing="false" onAction="#saveProfile"
                                        style="-fx-background-color: #00B894; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"
                                        text="Save Changes" visible="false">
                                    <padding><Insets bottom="10.0" left="20.0" right="20.0" top="10.0" /></padding>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </StackPane>
    </children>
</VBox>