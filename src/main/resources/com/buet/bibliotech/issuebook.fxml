<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_LEFT" prefHeight="700.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.issuebookController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <!-- Branding: Top Title -->
        <Label text="BiblioTech" textFill="#f2f5f9">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>

        <!-- Back Button Styled for Dark Theme -->
        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-text-fill: white;" text="← Back">
            <padding>
                <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
            </padding>
            <font>
                <Font size="14.0" />
            </font>
        </Button>

        <!-- Form Container -->
        <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <!-- Styled Card -->
                <VBox alignment="TOP_CENTER" maxWidth="650.0" prefWidth="650.0" spacing="25.0" style="-fx-background-color: #111c30; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 5);">
                    <padding>
                        <Insets bottom="50.0" left="50.0" right="50.0" top="40.0" />
                    </padding>
                    <children>
                        <Label alignment="TOP_LEFT" maxWidth="Infinity" text="Issue Book Transaction" textFill="#f2f5f9">
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                            <VBox.margin>
                                <Insets bottom="10.0" left="0.0" right="0.0" top="0.0" />
                            </VBox.margin>
                        </Label>

                        <VBox spacing="15.0">
                            <children>
                                <!-- Book Selection Row -->
                                <VBox spacing="8.0">
                                    <Label text="Book Name" textFill="#c7d1e0">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <ComboBox fx:id="booknamePicker" maxWidth="Infinity" promptText="- Select Available Book -" style="-fx-pref-height: 45; -fx-background-color: #0b1324; -fx-border-color: #223149; -fx-border-radius: 5; -fx-text-fill: white;" />
                                </VBox>

                                <!-- Student ID and Book ID Row -->
                                <HBox spacing="20.0">
                                    <children>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Student ID" textFill="#c7d1e0">
                                                    <font><Font name="System Bold" size="13.0" /></font>
                                                </Label>
                                                <ComboBox fx:id="studentidPicker" maxWidth="Infinity" promptText="- Select Member ID -" style="-fx-pref-height: 45; -fx-background-color: #0b1324; -fx-border-color: #223149; -fx-border-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                                            <Label text="Book ID" textFill="#c7d1e0">
                                                <font><Font name="System Bold" size="13.0" /></font>
                                            </Label>
                                            <TextField fx:id="booknumField" editable="false" promptText="Auto-filled ID" style="-fx-pref-height: 45; -fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-color: #0b1324; -fx-text-fill: #8b9bb4;" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <!-- Date Picker Row -->
                                <VBox spacing="8.0">
                                    <Label text="Issue Date" textFill="#c7d1e0">
                                        <font><Font name="System Bold" size="13.0" /></font>
                                    </Label>
                                    <HBox spacing="20.0">
                                        <children>
                                            <DatePicker fx:id="issuedatepicker" maxWidth="Infinity" promptText="Select Date" style="-fx-pref-height: 45; -fx-background-radius: 5;" HBox.hgrow="ALWAYS" />
                                        </children>
                                    </HBox>
                                </VBox>
                            </children>
                        </VBox>

                        <!-- Action Button -->
                        <Button mnemonicParsing="false" onAction="#issuedone" prefWidth="250.0" style="-fx-background-color: #1f3b6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Issue Book">
                            <font><Font size="16.0" /></font>
                            <padding><Insets bottom="12.0" left="0.0" right="0.0" top="12.0" /></padding>
                            <VBox.margin><Insets bottom="0.0" left="0.0" right="0.0" top="15.0" /></VBox.margin>
                        </Button>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>