<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="0.0" style="-fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.IssuedBooksController">
    <children>

        <!-- HEADER (Executive Dark Style) -->
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="25.0" right="25.0" /></padding>
            <children>
                <Label text="Issued Books Records" textFill="#f2f5f9">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
            </children>
        </HBox>

        <!-- SUMMARY CARD (Executive Dark Style) -->
        <HBox spacing="20.0">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <VBox prefWidth="220.0" style="-fx-background-color: #111c30; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 10, 0, 0, 4);">
                    <children>
                        <Label text="Total Issued Records" textFill="#c7d1e0"><font><Font size="12.0" /></font></Label>
                        <Label fx:id="IssuedBooksLabel" text="0" textFill="#f2f5f9"><font><Font name="System Bold" size="20.0" /></font></Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- TOOLBAR: Back & Search -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="← Back to Dashboard">
                    <padding><Insets bottom="7.0" left="12.0" right="12.0" top="7.0" /></padding>
                </Button>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="8.0">
                    <children>
                        <TextField fx:id="searchText" prefWidth="280.0" promptText="Search by Book or Member..." style="-fx-background-color: #111c30; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5; -fx-padding: 7;" />
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- ISSUED BOOKS TABLE (Executive Dark Style) -->
        <TableView fx:id="issuedTable" fixedCellSize="64.0" style="-fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colBookId" prefWidth="100.0" text="Book ID" />
                <TableColumn fx:id="colBookName" prefWidth="250.0" text="Book Name" />
                <TableColumn fx:id="colAuthor" prefWidth="180.0" text="Author" />
                <TableColumn fx:id="colMemberName" prefWidth="200.0" text="Issued To" />
                <TableColumn fx:id="colIssueDate" prefWidth="150.0" text="Issue Date" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <VBox.margin>
                <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
            </VBox.margin>
        </TableView>

    </children>
</VBox>