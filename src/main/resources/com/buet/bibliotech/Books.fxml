<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="0.0" style="-fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.BooksController">
    <children>

        <!-- HEADER (Friend's Style) -->
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="25.0" right="25.0" /></padding>
            <children>
                <Label text="Available Books" textFill="#f2f5f9">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button minHeight="27.0" mnemonicParsing="false" onAction="#AddBook" prefHeight="35.0" prefWidth="138.0" style="-fx-background-color: #8b0e20; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="+ Add New Book">
                    <font><Font size="12.0" /></font>
                </Button>
            </children>
        </HBox>

        <!-- SUMMARY CARDS (Friend's Style + Your Real Data IDs) -->
        <HBox spacing="20.0">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <VBox prefWidth="200.0" style="-fx-background-color: #111c30; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 4);">
                    <children>
                        <Label text="Total Collection" textFill="#c7d1e0"><font><Font size="12.0" /></font></Label>
                        <Label fx:id="totalBooksLabel" text="0" textFill="#f2f5f9"><font><Font name="System Bold" size="20.0" /></font></Label>
                    </children>
                </VBox>
                <VBox prefWidth="200.0" style="-fx-background-color: #111c30; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 4);">
                    <children>
                        <Label text="Currently Available" textFill="#c7d1e0"><font><Font size="12.0" /></font></Label>
                        <Label fx:id="AvailableBooksLabel" text="0" textFill="#8b0e20"><font><Font name="System Bold" size="20.0" /></font></Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- TOOLBAR (Friend's Style) -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-text-fill: white; -fx-cursor: hand;" text="← Back">
                    <padding><Insets bottom="7.0" left="12.0" right="12.0" top="7.0" /></padding>
                </Button>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="8.0">
                    <children>
                        <TextField fx:id="searchBooksText" prefWidth="220.0" promptText="Search books..." style="-fx-background-color: #111c30; -fx-text-fill: white; -fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5; -fx-padding: 7;" />
                        <Button mnemonicParsing="false" onAction="#searchBooks" style="-fx-background-color: #1f3b6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Search">
                            <padding><Insets bottom="7.0" left="15.0" right="15.0" top="7.0" /></padding>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- TABLE VIEW (Friend's Style + YOUR MULTIPLE COPIES COLUMNS) -->
        <TableView fx:id="booksTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" maxWidth="100.0" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="colTitle" prefWidth="280.0" text="Book Title" />
                <TableColumn fx:id="colAuthor" prefWidth="180.0" text="Author" />
                <TableColumn fx:id="colCategory" prefWidth="120.0" text="Category" />

                <!-- INTEGRATED: Your inventory columns -->
                <TableColumn fx:id="colTotal" prefWidth="80.0" text="Total" />
                <TableColumn fx:id="colAvailable" prefWidth="90.0" text="Available" />

                <TableColumn fx:id="colAction" prefWidth="100.0" text="Action" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <VBox.margin>
                <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
            </VBox.margin>
        </TableView>

    </children>
</VBox>