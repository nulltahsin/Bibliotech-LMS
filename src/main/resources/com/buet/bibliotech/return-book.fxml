<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox fx:controller="com.buet.bibliotech.ReturnBookController" alignment="TOP_LEFT" prefHeight="750.0" prefWidth="1050.0" spacing="20.0" style="-fx-background-color: #0b1324;" stylesheets="@theme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="40.0" left="50.0" right="50.0" top="30.0" />
    </padding>
    <children>
        <!-- Top Header Style (Synced with Dashboard) -->
        <Label text="BiblioTech" textFill="#f2f5f9">
            <font>
                <Font name="System Bold" size="30.0" />
            </font>
        </Label>

        <!-- Back Button Styled for Dark Theme -->
        <Button onAction="#switchToDashboard" mnemonicParsing="false" style="-fx-background-color: #111c30; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand; -fx-text-fill: white;" text="← Back">
            <padding>
                <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
            </padding>
            <font>
                <Font size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <!-- Centered Card Container -->
        <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <!-- Navy Blue Form Card -->
                <VBox alignment="TOP_CENTER" maxWidth="600.0" prefWidth="600.0" spacing="0.0" style="-fx-background-color: #111c30; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.4), 15, 0, 0, 5);">
                    <children>
                        <!-- Card Title Section -->
                        <VBox alignment="CENTER" prefHeight="80.0">
                            <children>
                                <Label text="Return Book Transaction" textFill="#f2f5f9">
                                    <font>
                                        <Font name="System Bold" size="24.0" />
                                    </font>
                                </Label>
                            </children>
                        </VBox>

                        <!-- Form Input Fields -->
                        <VBox spacing="25.0">
                            <padding>
                                <Insets bottom="40.0" left="60.0" right="60.0" top="10.0" />
                            </padding>
                            <children>
                                <!-- Book ID Field -->
                                <HBox alignment="CENTER_LEFT" spacing="20.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Book ID" textFill="#c7d1e0">
                                            <font>
                                                <Font name="System Bold" size="15.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="bookIdField" promptText="Enter Book ID" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-color: #0b1324; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Fine Amount Field -->
                                <VBox spacing="5.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="20.0">
                                            <children>
                                                <Label prefWidth="120.0" text="Fine Amount" textFill="#c7d1e0">
                                                    <font>
                                                        <Font name="System Bold" size="15.0" />
                                                    </font>
                                                </Label>
                                                <TextField fx:id="fineField" promptText="Amount (if any)" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #223149; -fx-border-radius: 5; -fx-background-color: #0b1324; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                                            </children>
                                        </HBox>
                                        <Label text="(leave blank if no fine)" textFill="#8b9bb4">
                                            <font>
                                                <Font size="12.0" />
                                            </font>
                                            <VBox.margin>
                                                <Insets left="140.0" />
                                            </VBox.margin>
                                        </Label>
                                    </children>
                                </VBox>

                                <!-- Action Button (Submit) -->
                                <VBox alignment="CENTER">
                                    <children>
                                        <Button onAction="#handleReturnBook" mnemonicParsing="false" prefWidth="250.0" style="-fx-background-color: #1f3b6a; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Confirm Return">
                                            <font>
                                                <Font size="16.0" />
                                            </font>
                                            <padding>
                                                <Insets bottom="12.0" top="12.0" />
                                            </padding>
                                        </Button>
                                    </children>
                                    <VBox.margin>
                                        <Insets top="10.0" />
                                    </VBox.margin>
                                </VBox>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>