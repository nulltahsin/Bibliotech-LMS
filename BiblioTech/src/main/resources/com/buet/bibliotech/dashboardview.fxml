<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.DashboardController">
    <children>
        <BorderPane prefHeight="200.0" prefWidth="200.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <AnchorPane prefHeight="88.0" prefWidth="1000.0" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" BorderPane.alignment="CENTER">
                    <children>
                        <Text layoutX="20.0" layoutY="55.0" strokeType="OUTSIDE" strokeWidth="0.0" text="BiblioTech" AnchorPane.leftAnchor="20.0" AnchorPane.topAnchor="30.0">
                            <font>
                                <Font name="Impact" size="28.0" />
                            </font>
                        </Text>
                        <HBox layoutY="-1.0" prefHeight="23.0" prefWidth="1000.0" style="-fx-background-color: transparent;" />
                    </children>
                </AnchorPane>
            </top>
            <left>
                <AnchorPane prefHeight="505.0" prefWidth="223.0" style="-fx-background-color: #f8f2e6;" BorderPane.alignment="CENTER">
                    <children>
                        <VBox layoutX="40.0" layoutY="134.0" prefHeight="200.0" prefWidth="100.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
                            <children>
                                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#bookspageshow" prefHeight="43.0" prefWidth="223.0" style="-fx-background-color: transparent;" text="Books">
                                    <font><Font name="Calibri" size="16.0" /></font>
                                    <graphic>
                                        <ImageView fitHeight="22.0" fitWidth="25.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@data.png" /></image>
                                        </ImageView>
                                    </graphic>
                                    <VBox.margin><Insets left="10.0" right="10.0" top="5.0" /></VBox.margin>
                                </Button>
                                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#memberspageshow" prefHeight="43.0" prefWidth="223.0" style="-fx-background-color: transparent;" text="Members">
                                    <font><Font name="Calibri" size="16.0" /></font>
                                    <graphic>
                                        <ImageView fitHeight="19.0" fitWidth="24.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@members.png" /></image>
                                        </ImageView>
                                    </graphic>
                                    <VBox.margin><Insets left="10.0" right="10.0" top="5.0" /></VBox.margin>
                                </Button>
                                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="43.0" prefWidth="223.0" style="-fx-background-color: transparent;" text="Returned Books">
                                    <font><Font name="Calibri" size="16.0" /></font>
                                    <graphic>
                                        <ImageView fitHeight="22.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@returnedicon.png" /></image>
                                        </ImageView>
                                    </graphic>
                                    <VBox.margin><Insets left="10.0" right="10.0" top="5.0" /></VBox.margin>
                                </Button>
                                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" prefHeight="43.0" prefWidth="223.0" style="-fx-background-color: transparent;" text="Reports">
                                    <font><Font name="Calibri" size="16.0" /></font>
                                    <graphic>
                                        <ImageView fitHeight="22.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                                            <image><Image url="@reportsicon.png" /></image>
                                        </ImageView>
                                    </graphic>
                                    <VBox.margin><Insets left="10.0" right="10.0" top="5.0" /></VBox.margin>
                                </Button>
                                <Button alignment="BASELINE_LEFT" mnemonicParsing="false" onAction="#LogOut" prefHeight="43.0" prefWidth="223.0" style="-fx-background-color: transparent;" text="Log Out">
                                    <font><Font name="Calibri" size="16.0" /></font>
                                    <graphic>
                                        <ImageView fitHeight="22.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true" style="-fx-background-color: transparent;">
                                            <image><Image url="@logoutn.jpg" /></image>
                                        </ImageView>
                                    </graphic>
                                    <VBox.margin><Insets left="10.0" right="10.0" top="5.0" /></VBox.margin>
                                </Button>
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </left>
            <center>
                <VBox prefHeight="200.0" prefWidth="100.0" style="-fx-background-color: #f5f5f5;" BorderPane.alignment="CENTER">
                    <children>
                        <!-- Stats Cards Row -->
                        <HBox prefHeight="120.0" spacing="20.0" VBox.vgrow="NEVER">
                            <VBox.margin><Insets bottom="10.0" left="20.0" right="20.0" top="20.0" /></VBox.margin>
                            <!-- Total Books Card -->
                            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                <padding><Insets left="15.0" /></padding>
                                <VBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Total Books" textFill="#666666"><font><Font name="Calibri Bold" size="13.0" /></font></Label>
                                    <Label fx:id="totalBooksLabel" text="1,250" textFill="#2c3e50"><font><Font name="System Bold" size="24.0" /></font></Label>
                                </VBox>
                            </HBox>
                            <!-- Total Members Card -->
                            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                <padding><Insets left="15.0" /></padding>
                                <VBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Total Members" textFill="#666666"><font><Font name="Calibri Bold" size="13.0" /></font></Label>
                                    <Label fx:id="totalMembersLabel" text="300" textFill="#2c3e50"><font><Font name="System Bold" size="24.0" /></font></Label>
                                </VBox>
                            </HBox>
                            <!-- Books Issued Card -->
                            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                <padding><Insets left="15.0" /></padding>
                                <VBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Books Issued" textFill="#666666"><font><Font name="Calibri Bold" size="13.0" /></font></Label>
                                    <Label fx:id="booksIssuedLabel" text="120" textFill="#2c3e50"><font><Font name="System Bold" size="24.0" /></font></Label>
                                </VBox>
                            </HBox>
                            <!-- Books Due Card -->
                            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="180.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                                <padding><Insets left="15.0" /></padding>
                                <VBox alignment="CENTER_LEFT" spacing="5.0">
                                    <Label text="Books Due" textFill="#666666"><font><Font name="Calibri Bold" size="13.0" /></font></Label>
                                    <Label fx:id="booksDueLabel" text="15" textFill="#e74c3c"><font><Font name="System Bold" size="24.0" /></font></Label>
                                </VBox>
                            </HBox>
                        </HBox>

                        <!-- Expanded Single Table Row -->
                        <VBox spacing="10.0" style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
                            <VBox.margin><Insets bottom="15.0" left="20.0" right="20.0" top="5.0" /></VBox.margin>
                            <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT">
                                    <children>
                                        <Label text="Pending Returns" textFill="#2c3e50">
                                            <font><Font name="System Bold" size="18.0" /></font>
                                        </Label>
                                        <HBox HBox.hgrow="ALWAYS" />
                                        <Label text="View All ›" textFill="#5B9BD5" underline="true">
                                            <font><Font size="13.0" /></font>
                                        </Label>
                                    </children>
                                </HBox>
                                <TableView fx:id="pendingReturnsTable" VBox.vgrow="ALWAYS">
                                    <columns>
                                        <TableColumn fx:id="colBookId" prefWidth="80.0" text="Book ID" />
                                        <TableColumn fx:id="colBookName" prefWidth="250.0" text="Book Name" />
                                        <TableColumn fx:id="colMemberId" prefWidth="100.0" text="Member ID" />
                                        <TableColumn fx:id="colMemberName" prefWidth="215.0" text="Member Name" />
                                        <TableColumn fx:id="colIssueDate" prefWidth="115.0" text="Issue Date" />
                                    </columns>
                                    <columnResizePolicy>
                                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                    </columnResizePolicy>
                                </TableView>
                            </children>
                        </VBox>

                        <!-- Action Buttons Row -->
                        <HBox alignment="CENTER" prefHeight="80.0" spacing="20.0">
                            <VBox.margin><Insets bottom="20.0" left="20.0" right="20.0" top="5.0" /></VBox.margin>
                            <Button mnemonicParsing="false" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #5B9BD5; -fx-background-radius: 10;" text="Accept Return" textFill="WHITE">
                                <font><Font name="System Bold" size="16.0" /></font>
                            </Button>
                            <Button mnemonicParsing="false" onAction="#handleIssueBook" prefHeight="50.0" prefWidth="350.0" style="-fx-background-color: #70AD47; -fx-background-radius: 10;" text="Issue Book" textFill="WHITE">
                                <font><Font name="System Bold" size="16.0" /></font>
                            </Button>
                        </HBox>
                    </children>
                </VBox>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
