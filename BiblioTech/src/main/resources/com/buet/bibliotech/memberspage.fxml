<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_LEFT" prefHeight="750.0" prefWidth="1100.0" spacing="20.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.memberspageController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="30.0" />
    </padding>
    <children>
        <!-- Header Section -->
        <VBox spacing="10.0">
            <children>
                <Label text="BiblioTech" textFill="#2c3e50">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>
                <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="← Back">
                    <padding>
                        <Insets bottom="8.0" left="20.0" right="20.0" top="8.0" />
                    </padding>
                    <font>
                        <Font size="14.0" />
                    </font>
                </Button>
            </children>
        </VBox>

        <!-- Page Title and Add Member Button -->
        <HBox alignment="CENTER_LEFT" spacing="20.0">
            <children>
                <Label text="Members Management" textFill="#343a40">
                    <font>
                        <Font name="System Bold" size="26.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button mnemonicParsing="false" onAction="#addmember" style="-fx-background-color: #4a90e2; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;" text="+ Add New Member">
                    <padding>
                        <Insets bottom="10.0" left="25.0" right="25.0" top="10.0" />
                    </padding>
                    <font>
                        <Font name="System Bold" size="14.0" />
                    </font>
                </Button>
            </children>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </HBox>

        <!-- Main Content Card (Table Container) -->
        <VBox spacing="20.0" style="-fx-background-color: #ffffff; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" VBox.vgrow="ALWAYS">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <!-- Search Bar Section -->
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #f1f3f5; -fx-background-radius: 5; -fx-padding: 8;">
                    <children>
                        <TextField fx:id="searchField" prefWidth="350.0" promptText="🔍 Search members by ID or name..." style="-fx-background-color: transparent; -fx-font-size: 14;" HBox.hgrow="ALWAYS" />
                    </children>
                </HBox>

                <!-- Members Table -->
                <TableView fx:id="membersTable" style="-fx-background-radius: 5; -fx-border-color: #dee2e6; -fx-border-radius: 5;" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idCol" prefWidth="100.0" text="ID" />
                        <TableColumn fx:id="nameCol" prefWidth="250.0" text="Member Name" />
                        <TableColumn fx:id="deptCol" prefWidth="200.0" text="Department" />
                        <TableColumn fx:id="batchCol" prefWidth="180.0" text="Batch" />
                        <TableColumn fx:id="actionCol" prefWidth="150.0" text="Action" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
