<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="1000.0" spacing="0.0" style="-fx-background-color: #F4F7F9;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.BooksController">
    <children>

        <!-- HEADER: Resized to 60px height -->
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: white; -fx-border-color: #E0E4E8; -fx-border-width: 0 0 1 0;">
            <padding><Insets left="25.0" right="25.0" /></padding>
            <children>
                <Label text="Available Books" textFill="#2D3436">
                    <font><Font name="System Bold" size="18.0" /></font>
                </Label>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Add Button: Compacted for 600 height -->
                <Button minHeight="27.0" mnemonicParsing="false" onAction="#AddBook" prefHeight="27.0" prefWidth="138.0" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="+ Add New Book">
                    <padding><Insets bottom="8.0" left="15.0" right="15.0" top="8.0" /></padding>
                    <font><Font size="10.0" /></font>
                </Button>
            </children>
        </HBox>

        <!-- SUMMARY CARDS: Shorter height (approx 80px) -->
        <HBox spacing="20.0">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                    <children>
                        <Label text="Total Collection" textFill="#636E72"><font><Font size="12.0" /></font></Label>
                        <Label text="1,250" textFill="#2D3436"><font><Font name="System Bold" size="20.0" /></font></Label>
                    </children>
                </VBox>
                <VBox prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.06), 10, 0, 0, 4);">
                    <children>
                        <Label text="Currently Available" textFill="#636E72"><font><Font size="12.0" /></font></Label>
                        <Label text="1,130" textFill="#00B894"><font><Font name="System Bold" size="20.0" /></font></Label>
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- TOOLBAR: Back & Search (Same Level, tightened spacing) -->
        <HBox alignment="CENTER_LEFT">
            <padding><Insets left="25.0" right="25.0" top="20.0" /></padding>
            <children>
                <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: white; -fx-border-color: #D1D1D1; -fx-border-radius: 5; -fx-cursor: hand;" text="← Back">
                    <padding><Insets bottom="7.0" left="12.0" right="12.0" top="7.0" /></padding>
                </Button>

                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="8.0">
                    <children>
                        <TextField fx:id="searchBooksText" prefWidth="220.0" promptText="Search books..." style="-fx-background-radius: 5; -fx-border-color: #CFD8DC; -fx-border-radius: 5; -fx-padding: 7;" />
                        <Button mnemonicParsing="false" onAction="#searchBooks" style="-fx-background-color: #1A73E8; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Search">
                            <padding><Insets bottom="7.0" left="15.0" right="15.0" top="7.0" /></padding>
                        </Button>
                    </children>
                </HBox>
            </children>
        </HBox>

        <!-- TABLE VIEW: Maximized for the remaining 600px height -->
        <TableView fx:id="booksTable" VBox.vgrow="ALWAYS">
            <columns>
                <!-- Book ID row made small (70px) -->
                <TableColumn fx:id="colId" maxWidth="100.0" prefWidth="70.0" text="ID" />
                <TableColumn fx:id="colTitle" prefWidth="380.0" text="Book Title" />
                <TableColumn fx:id="colAuthor" prefWidth="240.0" text="Author" />
                <TableColumn fx:id="colCategory" prefWidth="160.0" text="Category" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <VBox.margin>
                <Insets bottom="20.0" left="25.0" right="25.0" top="15.0" />
            </VBox.margin>
        </TableView>

    </children>
</VBox>
