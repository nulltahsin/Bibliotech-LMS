<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="TOP_LEFT" prefHeight="700.0" prefWidth="1000.0" spacing="20.0" style="-fx-background-color: #f6f5f3;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.buet.bibliotech.addmemberController">
    <padding>
        <Insets bottom="40.0" left="50.0" right="50.0" top="30.0" />
    </padding>
    <children>
        <!-- Top Branding -->
        <Label text="BiblioTech" textFill="#2c3e50">
            <font>
                <Font name="System Bold" size="30.0" />
            </font>
        </Label>
      <Separator prefWidth="200.0" />

        <!-- Back Button -->
        <Button mnemonicParsing="false" onAction="#handleBack" style="-fx-background-color: #ffffff; -fx-border-color: #ced4da; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="← Back">
            <padding>
                <Insets bottom="8.0" left="18.0" right="18.0" top="8.0" />
            </padding>
            <font>
                <Font size="14.0" />
            </font>
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
        </Button>

        <!-- Horizontal Box to Center the Form Card -->
        <HBox alignment="CENTER" VBox.vgrow="ALWAYS">
            <children>
                <!-- Main Form Card Container -->
                <VBox alignment="TOP_CENTER" maxWidth="700.0" prefWidth="700.0" spacing="0.0" style="-fx-background-color: #ffffff; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
                    <children>
                        <!-- Form Header -->
                        <VBox alignment="CENTER" prefHeight="80.0">
                            <children>
                                <Label text="Register New Member" textFill="#212529">
                                    <font>
                                        <Font name="System Bold" size="22.0" />
                                    </font>
                                </Label>
                            </children>
                            <VBox.margin>
                                <Insets bottom="10.0" left="0.0" right="0.0" top="0.0" />
                            </VBox.margin>
                        </VBox>

                        <!-- Separator Line (Optional visual) -->
                        <Region prefHeight="1.0" style="-fx-background-color: #eee;">
                            <VBox.margin>
                                <Insets bottom="30.0" left="30.0" right="30.0" top="0.0" />
                            </VBox.margin>
                        </Region>

                        <!-- Form Content -->
                        <VBox spacing="20.0">
                            <padding>
                                <Insets bottom="30.0" left="50.0" right="50.0" top="0.0" />
                            </padding>
                            <children>
                                <!-- Full Name Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Full Name *" textFill="#333">
                                            <font>
                                                <Font name="System" size="15.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="nameField" promptText="Full Name" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Member ID Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Member ID *" textFill="#333">
                                            <font>
                                                <Font name="System" size="15.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="idField" promptText="Member ID" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Department Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Department *" textFill="#333">
                                            <font>
                                                <Font name="System" size="15.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="departmentField" promptText="Department" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Batch Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Batch *" textFill="#333">
                                            <font>
                                                <Font name="System" size="15.0" />
                                            </font>
                                        </Label>
                                        <TextField fx:id="batchField" promptText="Batch" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" HBox.hgrow="ALWAYS" />
                                    </children>
                                </HBox>

                                <!-- Joining Date Row -->
                                <HBox alignment="CENTER_LEFT" spacing="30.0">
                                    <children>
                                        <Label prefWidth="120.0" text="Email *" textFill="#333">
                                            <font>
                                                <Font name="System" size="15.0" />
                                            </font>
                                        </Label>
                              <TextField fx:id="emailField" prefHeight="27.0" prefWidth="451.0" promptText="Email ID" style="-fx-pref-height: 40; -fx-background-radius: 5; -fx-border-color: #ddd; -fx-border-radius: 5;" />
                                    </children>
                                </HBox>
                            </children>
                        </VBox>

                        <!-- Footer Actions (Buttons) -->
                        <HBox alignment="CENTER" prefHeight="90.0" spacing="15.0" style="-fx-background-color: #fcfcfc; -fx-background-radius: 0 0 15 15; -fx-border-color: #eee; -fx-border-width: 1 0 0 0;">
                            <children>
                                <Button fx:id="registerButton" mnemonicParsing="false" onAction="#savemember" prefWidth="180.0" style="-fx-background-color: #1976D2; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="Register Member">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                    <padding>
                                        <Insets bottom="10.0" left="0.0" right="0.0" top="10.0" />
                                    </padding>
                                </Button>
                                <Button fx:id="clearButton" mnemonicParsing="false" onAction="#clearFields" prefWidth="120.0" style="-fx-background-color: #ffffff; -fx-text-fill: #555; -fx-font-weight: bold; -fx-border-color: #ddd; -fx-border-radius: 5; -fx-background-radius: 5; -fx-cursor: hand;" text="Clear">
                                    <font>
                                        <Font size="15.0" />
                                    </font>
                                    <padding>
                                        <Insets bottom="10.0" left="0.0" right="0.0" top="10.0" />
                                    </padding>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                    <VBox.margin>
                        <Insets bottom="50.0" left="0.0" right="0.0" top="20.0" />
                    </VBox.margin>
                </VBox>
            </children>
        </HBox>
    </children>
</VBox>
